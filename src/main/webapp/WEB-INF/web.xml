<?xml version="1.0" encoding="UTF-8"?>
<web-app version="4.0" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">
    <servlet>
        <servlet-name>PacienteControl</servlet-name>
        <servlet-class>servlets.PacienteControl</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>MedicoControl</servlet-name>
        <servlet-class>servlets.MedicoControl</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CitaMedicaControl</servlet-name>
        <servlet-class>servlets.CitaMedicaControl</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UsuarioControl</servlet-name>
        <servlet-class>servlets.UsuarioControl</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PacienteControl</servlet-name>
        <url-pattern>/PacienteControl</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>MedicoControl</servlet-name>
        <url-pattern>/MedicoControl</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CitaMedicaControl</servlet-name>
        <url-pattern>/CitaMedicaControl</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UsuarioControl</servlet-name>
        <url-pattern>/UsuarioControl</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
